# TenderBriefing — Firebase project: tenderbriefing (tenderbriefing-34679)

# Storage: json (local) | firestore (production)
STORAGE_ADAPTER=firestore
FIREBASE_PROJECT_ID=tenderbriefing-34679
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Optional: inline service account JSON (single line) instead of file
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Scheduled sync auth (required in production for POST /api/sync/run)
SYNC_SECRET=change-this-secure-value

# OpenAI (optional — rule-based summaries when empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Public site URL (SEO, sitemap, OpenGraph). Cloud Run fallback remains active.
NEXT_PUBLIC_SITE_URL=https://www.tenderbriefing.co.za

# Firebase client (browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tenderbriefing-34679.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tenderbriefing-34679
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tenderbriefing-34679.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=9058655644
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
