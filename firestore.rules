rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userType() {
      return userDoc().data.userType;
    }

    function isAdmin() {
      return isAuthenticated() && userDoc().exists && userType() == 'admin';
    }

    function isSme() {
      return isAuthenticated() && userDoc().exists && userType() == 'sme';
    }

    function isYouthAgent() {
      return isAuthenticated() && userDoc().exists && userType() == 'youth-agent';
    }

    // Legacy user profiles
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAuthenticated();
    }

    // TenderBriefing platform — procurement intelligence
    match /tenderBriefings/{tenderId} {
      allow read: if isAuthenticated() && (
        isAdmin()
        || !('visibility' in resource.data) || resource.data.visibility != 'private'
        || (isSme() && resource.data.ownerUid == request.auth.uid)
      );
      allow write: if isAdmin();
    }

    match /attendanceRequests/{requestId} {
      allow create: if isSme()
        && request.resource.data.smeId == request.auth.uid;
      allow read: if isAdmin()
        || (isSme() && resource.data.smeId == request.auth.uid)
        || (isYouthAgent() && (
          resource.data.agentId == request.auth.uid
          || ('notifiedAgents' in resource.data
            && request.auth.uid in resource.data.notifiedAgents)
        ));
      allow update: if isAdmin()
        || (isYouthAgent() && resource.data.agentId == request.auth.uid)
        || (isSme() && resource.data.smeId == request.auth.uid);
    }

    match /briefingReports/{reportId} {
      allow create: if isYouthAgent()
        && request.resource.data.agentId == request.auth.uid;
      allow read: if isAdmin()
        || (isYouthAgent() && resource.data.agentId == request.auth.uid)
        || isSme();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /syncStatus/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
    }

    match /workflowEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /dispatchEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /executiveMetrics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /slaBreaches/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /agentPerformanceSnapshots/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /workflowFailures/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /pilotLeads/{leadId} {
      allow read, write: if isAdmin();
    }

    match /pilotOutreach/{outreachId} {
      allow read, write: if isAdmin();
    }

    match /pilotTasks/{taskId} {
      allow read, write: if isAdmin();
    }

    match /pilotFeedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /gpsAttendanceLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isYouthAgent();
      allow write: if false;
    }

    match /dispatchTracking/{docId} {
      allow read: if isAdmin() || isYouthAgent();
      allow write: if isAdmin();
    }

    match /fraudAlerts/{alertId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /financePayouts/{payoutId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /financeInvoices/{invoiceId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /financeTransactions/{txId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /aiTenderInsights/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /aiBriefingInsights/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /agentVerification/{agentId} {
      allow read: if isAdmin() || (isYouthAgent() && request.auth.uid == agentId);
      allow create, update: if isYouthAgent() && request.auth.uid == agentId;
      allow write: if isAdmin();
    }

    match /operationalIncidents/{incidentId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow write: if false;
    }

    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isYouthAgent() && request.auth.uid == agentId);
    }

    match /smes/{smeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isSme() && request.auth.uid == smeId);
    }

  match /smeWorkspace/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId && isSme();

      match /savedTenders/{tenderId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId && isSme();
      }

      match /trackedTenders/{tenderId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId && isSme();
      }

      match /watchedDepartments/{departmentId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId && isSme();
      }

      match /watchedProvinces/{provinceId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId && isSme();
      }
    }

    // Legacy collections (TenderConnect)
    match /tenders/{tenderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /scraped_tenders/{tenderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
        (resource.data.entrepreneurId == request.auth.uid ||
         resource.data.connectorId == request.auth.uid ||
         resource.data.smeId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.entrepreneurId == request.auth.uid ||
         resource.data.connectorId == request.auth.uid ||
         resource.data.smeId == request.auth.uid);
    }

    match /submissions/{submissionId} {
      allow read, write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && resource.data.raterId == request.auth.uid;
    }

    match /scraping_jobs/{jobId} {
      allow read, write: if isAdmin();
    }

    match /connectorAvailability/{docId} {
      allow read: if isAuthenticated();
      allow write: if isYouthAgent() || isAdmin();
    }

    match /mobileSessions/{sessionId} {
      allow read: if isAdmin() || (isYouthAgent() && resource.data.agentId == request.auth.uid);
      allow create: if isYouthAgent() && request.resource.data.agentId == request.auth.uid;
      allow update: if isAdmin() || (isYouthAgent() && resource.data.agentId == request.auth.uid);
    }

    match /mobileSyncQueue/{itemId} {
      allow read: if isAdmin() || (isYouthAgent() && resource.data.agentId == request.auth.uid);
      allow create: if isYouthAgent() && request.resource.data.agentId == request.auth.uid;
      allow update: if isAdmin() || (isYouthAgent() && resource.data.agentId == request.auth.uid);
    }

    match /mobileTelemetry/{eventId} {
      allow read: if isAdmin() || (isYouthAgent() && resource.data.agentId == request.auth.uid);
      allow create: if isYouthAgent() && request.resource.data.agentId == request.auth.uid;
    }

    match /agentLocationPings/{pingId} {
      allow read: if isAdmin() || (isYouthAgent() && resource.data.agentId == request.auth.uid);
      allow create: if isYouthAgent() && request.resource.data.agentId == request.auth.uid;
    }

    match /procurementSources/{sourceId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /aiProcurementExtraction/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /procurementGraphMetrics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /procurementSourceLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /ingestedProcurementEmails/{emailId} {
      allow read: if isAdmin()
        || (isSme() && resource.data.forwardedByUid == request.auth.uid);
      allow create: if isAdmin()
        || (isSme() && request.resource.data.forwardedByUid == request.auth.uid);
      allow update: if isAdmin()
        || (isSme() && resource.data.forwardedByUid == request.auth.uid);
    }

    match /dispatchAutomationLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /attendanceRiskPredictions/{docId} {
      allow read: if isAdmin()
        || (isSme() && resource.data.requestId != null);
      allow write: if false;
    }

    match /rfqTriageResults/{docId} {
      allow read: if isAdmin()
        || (isSme() && resource.data.forwardedByUid == request.auth.uid);
      allow write: if false;
    }

    match /procurementWatchlists/{smeUid} {
      allow read: if isAdmin() || (isSme() && request.auth.uid == smeUid);
      allow write: if false;
    }

    match /submissionReadinessReports/{docId} {
      allow read: if isAdmin()
        || (isSme() && docId.matches('^' + request.auth.uid + '(_|$)'));
      allow write: if false;
    }

    match /dailyProcurementBriefs/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /workflowEscalations/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /executiveBriefingSummaries/{docId} {
      allow read: if isAdmin() || isSme();
      allow write: if false;
    }

    match /procurementMemory/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /pricingOptimizationLogs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /fraudAutomationInsights/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /procurementForecasts/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /calendarIntelligenceInsights/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /enterpriseFieldOps/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
