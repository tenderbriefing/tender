rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userType() {
      return userDoc().data.userType;
    }

    function isAdmin() {
      return isAuthenticated() && userDoc().exists && userType() == 'admin';
    }

    function isSme() {
      return isAuthenticated() && userDoc().exists && userType() == 'sme';
    }

    function isYouthAgent() {
      return isAuthenticated() && userDoc().exists && userType() == 'youth-agent';
    }

    // Legacy user profiles
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAuthenticated();
    }

    // TenderBriefing platform — procurement intelligence
    match /tenderBriefings/{tenderId} {
      allow read: if isAuthenticated() && (isSme() || isYouthAgent() || isAdmin());
      allow write: if isAdmin();
    }

    match /attendanceRequests/{requestId} {
      allow create: if isSme()
        && request.resource.data.smeId == request.auth.uid;
      allow read: if isAdmin()
        || (isSme() && resource.data.smeId == request.auth.uid)
        || (isYouthAgent() && (
          resource.data.agentId == request.auth.uid
          || ('notifiedAgents' in resource.data
            && request.auth.uid in resource.data.notifiedAgents)
        ));
      allow update: if isAdmin()
        || (isYouthAgent() && resource.data.agentId == request.auth.uid)
        || (isSme() && resource.data.smeId == request.auth.uid);
    }

    match /briefingReports/{reportId} {
      allow create: if isYouthAgent()
        && request.resource.data.agentId == request.auth.uid;
      allow read: if isAdmin()
        || (isYouthAgent() && resource.data.agentId == request.auth.uid)
        || isSme();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /syncStatus/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
    }

    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isYouthAgent() && request.auth.uid == agentId);
    }

    match /smes/{smeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isSme() && request.auth.uid == smeId);
    }

    // Legacy collections (TenderConnect)
    match /tenders/{tenderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /scraped_tenders/{tenderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
        (resource.data.entrepreneurId == request.auth.uid ||
         resource.data.connectorId == request.auth.uid ||
         resource.data.smeId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.entrepreneurId == request.auth.uid ||
         resource.data.connectorId == request.auth.uid ||
         resource.data.smeId == request.auth.uid);
    }

    match /submissions/{submissionId} {
      allow read, write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && resource.data.raterId == request.auth.uid;
    }

    match /scraping_jobs/{jobId} {
      allow read, write: if isAdmin();
    }

    match /connectorAvailability/{docId} {
      allow read: if isAuthenticated();
      allow write: if isYouthAgent() || isAdmin();
    }
  }
}
