# Public site URL (canonical / OpenGraph)
NEXT_PUBLIC_SITE_URL=https://www.tenderbriefing.co.za

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Admin Configuration
ADMIN_EMAIL=admin@tenderconnect.com

# TenderBriefing platform storage: json (local) | firestore (production)
STORAGE_ADAPTER=json
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=
SYNC_SECRET=change-this-secure-value
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Platform integrations (see docs/API_INTEGRATIONS.md) ---

# Twilio WhatsApp (production — Secret Manager on Cloud Run)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Business API (optional legacy integration)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# Google Maps Platform
GOOGLE_MAPS_API_KEY=

# Yoco Payments (server only — never expose YOCO_SECRET_KEY to the browser)
YOCO_SECRET_KEY=
YOCO_WEBHOOK_SECRET=
NEXT_PUBLIC_ATTENDANCE_FEE_CENTS=24900
NEXT_PUBLIC_ATTENDANCE_FEE_LABEL=R249.00

# Firebase Storage (server — also set NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET)
FIREBASE_STORAGE_BUCKET=

# Firebase Cloud Messaging (legacy server key; prefer Firebase Admin in production)
FCM_SERVER_KEY=

# Google Analytics 4 (browser)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console (HTML tag verification content value)
GOOGLE_SITE_VERIFICATION=

# Google Calendar API (future)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Microsoft Graph (future)
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_TENANT_ID=
