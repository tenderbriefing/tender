# Public site URL (canonical / OpenGraph)
NEXT_PUBLIC_SITE_URL=https://www.tenderbriefing.co.za

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Admin Configuration
ADMIN_EMAIL=admin@tenderconnect.com

# TenderBriefing platform storage: json (local) | firestore (production)
STORAGE_ADAPTER=json
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=
SYNC_SECRET=change-this-secure-value
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
