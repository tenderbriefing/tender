rules_version = '2';

// Firebase Storage Security Rules for TenderConnect
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload files to their own folders
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to upload tender-related files
    match /tenders/{tenderId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to upload booking-related files
    match /bookings/{bookingId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to upload submission files (attendance proof, etc.)
    match /submissions/{submissionId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Briefing attendance proof (see docs/API_INTEGRATIONS.md — enable Storage in console first)
    match /briefing-proofs/{requestId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow public read access to profile pictures and public documents
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow admins to access all files
    match /{allPaths=**} {
      allow read, write: if request.auth != null && 
        exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.userType == 'admin';
    }
  }
}